{
  "productName": "Star Control",
  "version": "0.3.3",
  "identifier": "com.starcontrol.launcher",
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Game",
    "shortDescription": "A Linux management tool for Star Citizen"
  },
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Star Control",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 700,
        "decorations": false,
        "center": true
      }
    ]
  }
}
